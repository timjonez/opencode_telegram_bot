{
  "name": "opencode-telegram-plugin",
  "version": "0.1.0",
  "description": "Control OpenCode from your phone via Telegram. Send prompts, manage sessions, run shell commands, approve permissions, and execute any OpenCode slash command.",
  "type": "module",
  "main": "./dist/telegram-plugin.js",
  "types": "./dist/telegram-plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/telegram-plugin.js",
      "types": "./dist/telegram-plugin.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./telegram-plugin.ts --outdir ./dist --target node",
    "build:types": "tsc --emitDeclarationOnly --outDir ./dist",
    "build:all": "bun run build && bun run build:types",
    "prepublishOnly": "bun run build:all",
    "dev": "bun build ./telegram-plugin.ts --outdir ./dist --target node --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "telegram",
    "remote-control",
    "ai",
    "cli"
  ],
  "author": "Tim Jones <timjonez@protonmail.com>[](https://github.com/timjonez)",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "dependencies": {
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": ">=0.1.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timjonez/opencode_telegram_plugin.git"
  },
  "bugs": {
    "url": "https://github.com/timjonez/opencode_telegram_plugin/issues"
  },
  "homepage": "https://github.com/timjonez/opencode_telegram_plugin#readme"
}
